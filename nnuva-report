    history_file = Path.home() / '.nnuva' / 'history.json'
    
    if not cache_file.exists():
        print("Error: NNUVA cache not found. Run a scan with 'nnuva' first.")
        return

    try:
        cache_stat = cache_file.stat()
        cache_size_mb = round(cache_stat.st_size / (1024 * 1024), 2)
        cache_mtime = datetime.fromtimestamp(cache_stat.st_mtime).strftime('%Y-%m-%d %H:%M:%S')
    except Exception:
        cache_size_mb = 0
        cache_mtime = "Unknown"

    try:
        with open(cache_file, 'r', encoding='utf-8') as f:
            cache_data = json.load(f)
    except Exception as e:
        print(f"Error reading cache: {e}")
        return

    if not cache_data:
        print("Cache is empty. Nothing to report.")
        return

    print("Parsing raw ffprobe data via nnuva engine...")
    
    total_files = 0
    total_bytes = 0
    
    res_counts = Counter()
    res_size_bytes = defaultdict(int)
    nqi_counts = Counter()
    nqi_size_bytes = defaultdict(int)
    
    all_files = []

    prefix = f"v{nnuva.CACHE_VERSION}_"
    
    for key, raw_ffprobe in cache_data.items():
        if not key.startswith(prefix):
            continue 
            
        try:
            parts = key[len(prefix):].split('_')
            mtime = parts.pop()
            size_bytes = int(parts.pop())
            file_path = Path('_'.join(parts))
        except Exception:
            continue

        parsed_data = nnuva.parse_ffprobe_data(
            data=raw_ffprobe, 
            filepath=file_path, 
            size_bytes=size_bytes, 
            dir_name=str(file_path.parent), 
            nqi_audio=False
        )
        
        if parsed_data.get('error') or parsed_data.get('skip'):
            continue
            
        total_files += 1
        total_bytes += size_bytes
        
        res = parsed_data.get('RES', 'Unknown')
        res_counts[res] += 1
        res_size_bytes[res] += size_bytes
        
        nqi_val = str(parsed_data.get('NQI', 'Unknown'))
        nqi_counts[nqi_val] += 1
        nqi_size_bytes[nqi_val] += size_bytes
        
        all_files.append(parsed_data)

    optimal_count = nqi_counts.get('4', 0) + nqi_counts.get('5', 0)
    transcode_count = nqi_counts.get('6', 0) + nqi_counts.get('7', 0)
    upgrade_count = nqi_counts.get('1', 0) + nqi_counts.get('2', 0)
    
    total_gb = int(total_bytes / (1024**3))

    current_snapshot = {
        "date": datetime.now().strftime('%Y-%m-%d'),
        "total_files": total_files,
        "total_gb": total_gb,
        "optimal": optimal_count,
        "transcode": transcode_count,
        "upgrade": upgrade_count,
        "nqi": {
            "counts": dict(nqi_counts),
            "sizes_gb": {k: round(v / (1024**3), 2) for k, v in nqi_size_bytes.items()}
        }
    }
    history_log = update_history(current_snapshot)
    
    if len(history_log) == 1:
        fake_entry = copy.deepcopy(history_log[0])
        curr_date = datetime.strptime(fake_entry['date'], '%Y-%m-%d')
        fake_entry['date'] = (curr_date - timedelta(days=1)).strftime('%Y-%m-%d')
        history_log.insert(0, fake_entry)
    
    try:
        hist_stat = history_file.stat()
