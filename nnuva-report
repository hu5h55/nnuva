        hist_entries = len(history_log)
    except Exception:
        hist_size_kb = 0
        hist_mtime = "Unknown"
        hist_entries = 0

    minified_files = []
    for f in all_files:
        raw_audio = f.get('AUDIO', 'Unknown')
        base_audio = raw_audio.split(' ')[0] if raw_audio != 'N/A' else 'Unknown'
        minified_files.append({
            'file': f.get('file', 'Unknown'),
            'dir': f.get('dir', 'Unknown'),
            'RES': f.get('RES', 'Unknown'),
            'NQI': str(f.get('NQI', 'Unknown')),
            'VIDEO': f.get('VIDEO', 'Unknown'),
            'AUDIO': f.get('AUDIO', 'Unknown'),
            'AUDIO_BASE': base_audio,
            'HDR': f.get('HDR', 'Unknown'),
            'size_bytes': f.get('size_bytes', 0),
            'SIZE': f.get('SIZE', '0B'),
            'DUR': f.get('DUR', 'N/A'),
            'BITRATE': f.get('BITRATE', 'N/A'),
            'FPS': f.get('FPS', 'N/A'),
            'DEPTH': f.get('DEPTH', 'N/A'),
            'LANG': f.get('LANG', 'N/A'),
            'SUBS': f.get('SUBS', 'N/A')
        })

    html_content = f"""<!DOCTYPE html>
