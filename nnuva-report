        const formatTbRaw = (bytes) => (bytes / (1024**4)).toFixed(2);

        // --- GLOBAL CLIPBOARD COPY ---
        window.copyCmd = function() {{
            const codeEl = document.getElementById('transcodeCmd');
            if (codeEl) {{
                navigator.clipboard.writeText(codeEl.innerText).then(() => {{
                    const btn = document.getElementById('copyBtn');
                    btn.innerText = 'Copied!';
                    btn.style.background = '#34d399';
                    btn.style.color = '#0f172a';
                    setTimeout(() => {{
                        btn.innerText = 'Copy Bash';
                        btn.style.background = '#334155';
                        btn.style.color = '#f8fafc';
                    }}, 2000);
                }});
            }}
        }};

        // --- DEEP DIVE MODAL LOGIC ---
        const closeFileModal = () => {{
            document.getElementById('fileModal').style.display = 'none';
        }};

        window.onclick = function(event) {{
            const modal = document.getElementById('fileModal');
            if (event.target == modal) {{
                closeFileModal();
            }}
        }};

        const openFileModal = (id) => {{
            const f = rawFiles[id];
            document.getElementById('modalFileName').innerText = f.file;

            let action = "";
            let actionColor = "#94a3b8";
            if (['6','7'].includes(f.NQI)) {{ action = "High Priority Transcode (Overkill Bitrate)"; actionColor = "#d946ef"; }}
            else if (['1','2'].includes(f.NQI)) {{ action = "High Priority Upgrade (Low Quality)"; actionColor = "#f87171"; }}
            else if (['4','5'].includes(f.NQI)) {{ action = "Optimal Quality - Retain file."; actionColor = "#34d399"; }}
            else action = "Acceptable Footprint - Retain file.";

            let bashBlock = "";
            if (['6', '7'].includes(f.NQI)) {{
                const safeDir = f.dir === 'CURRENT DIRECTORY' ? '.' : f.dir;
                const fullPath = `${{safeDir}}/${{f.file}}`;
                const outPath = fullPath.replace(/\.[^/.]+$/, "") + "_optimal.mkv";
                const cmd = `HandBrakeCLI -i "${{fullPath}}" -o "${{outPath}}" --encoder nvenc_h265 --encoder-preset slower --quality 22 --all-audio --aencoder ffac3 --ab 640 --mixdown 5point1 --all-subtitles`;
                
                bashBlock = `
                    <div style="grid-column: 1 / -1; margin-top: 10px; background: #020617; padding: 15px; border-radius: 6px; border: 1px solid #334155;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
                            <span style="color: #d946ef; font-size: 0.85rem; font-weight: bold; text-transform: uppercase;">🛠️ Transcode Remediation Command</span>
                            <button id="copyBtn" onclick="copyCmd()" style="background: #334155; border: 1px solid #475569; color: #f8fafc; padding: 4px 12px; border-radius: 4px; cursor: pointer; font-size: 0.8rem; transition: all 0.2s;">Copy Bash</button>
                        </div>
                        <code id="transcodeCmd" style="color: #34d399; font-size: 0.85rem; word-break: break-all; font-family: monospace; display: block; padding: 10px; background: #0f172a; border-radius: 4px;">${{cmd}}</code>
                    </div>
                `;
            }}

            document.getElementById('modalBody').innerHTML = `
                <div class="modal-section" style="grid-column: 1 / -1;">
                    <h4>File Location & Status</h4>
                    <div class="modal-kv"><span class="modal-k">Directory:</span><span class="modal-v" style="color: #38bdf8;">${{f.dir}}</span></div>
                    <div class="modal-kv"><span class="modal-k">Health Score:</span><span class="modal-v"><span class="badge" style="background-color: ${{getNqiColor(f.NQI)}}; color: ${{getNqiTextColor(f.NQI)}};">NQI ${{f.NQI}}</span></span></div>
                    <div class="modal-kv"><span class="modal-k">Recommendation:</span><span class="modal-v" style="color: ${{actionColor}};">${{action}}</span></div>
                </div>
                <div class="modal-section">
                    <h4>Video Properties</h4>
                    <div class="modal-kv"><span class="modal-k">Resolution:</span><span class="modal-v">${{f.RES}}</span></div>
                    <div class="modal-kv"><span class="modal-k">Codec:</span><span class="modal-v">${{f.VIDEO}}</span></div>
                    <div class="modal-kv"><span class="modal-k">Bitrate:</span><span class="modal-v">${{f.BITRATE}}</span></div>
                    <div class="modal-kv"><span class="modal-k">Framerate:</span><span class="modal-v">${{f.FPS}}</span></div>
                    <div class="modal-kv"><span class="modal-k">Color / HDR:</span><span class="modal-v">${{f.HDR}}</span></div>
                    <div class="modal-kv"><span class="modal-k">Bit Depth:</span><span class="modal-v">${{f.DEPTH}}</span></div>
                </div>
                <div class="modal-section">
                    <h4>Audio & Metadata</h4>
                    <div class="modal-kv"><span class="modal-k">File Size:</span><span class="modal-v">${{f.SIZE}}</span></div>
                    <div class="modal-kv"><span class="modal-k">Duration:</span><span class="modal-v">${{f.DUR}}</span></div>
                    <div class="modal-kv"><span class="modal-k">Audio Codec:</span><span class="modal-v">${{f.AUDIO}}</span></div>
                    <div class="modal-kv"><span class="modal-k">Languages:</span><span class="modal-v">${{f.LANG}}</span></div>
                    <div class="modal-kv"><span class="modal-k">Subtitles:</span><span class="modal-v">${{f.SUBS || 'None'}}</span></div>
                </div>
                ${{bashBlock}}
            `;
            
            document.getElementById('fileModal').style.display = 'flex';
        }};


        // --- CROSSFILTER PIPELINE ---
        const runFilterPipeline = () => {{
            let currentData = rawFiles.filter(f => {{
                if (activeFilters.RES && f.RES !== activeFilters.RES) return false;
                if (activeFilters.NQI && f.NQI !== activeFilters.NQI) return false;
                if (activeFilters.VIDEO && f.VIDEO !== activeFilters.VIDEO) return false;
                if (activeFilters.AUDIO_BASE && f.AUDIO_BASE !== activeFilters.AUDIO_BASE) return false;
                if (activeFilters.HDR && f.HDR !== activeFilters.HDR) return false;
                return true;
            }});

            renderFilterBar();

            let tFiles = currentData.length;
            let tBytes = currentData.reduce((sum, f) => sum + f.size_bytes, 0);
            let cOpt = currentData.filter(f => ['4','5'].includes(f.NQI)).length;
            let cTrn = currentData.filter(f => ['6','7'].includes(f.NQI)).length;
            let cUpg = currentData.filter(f => ['1','2'].includes(f.NQI)).length;

            document.getElementById('kpi-files').innerText = tFiles.toLocaleString();
            document.getElementById('kpi-storage').innerText = formatGb(tBytes);
            document.getElementById('kpi-optimal').innerText = cOpt.toLocaleString();
            document.getElementById('kpi-transcode').innerText = cTrn.toLocaleString();
            document.getElementById('kpi-upgrade').innerText = cUpg.toLocaleString();

            updateBottomCharts(currentData);
            updateTables(currentData);
        }};

        const renderFilterBar = () => {{
            const bar = document.getElementById('filterBar');
            const pills = document.getElementById('filterPills');
            const masterReset = document.getElementById('masterResetBtn');
            pills.innerHTML = '';
            let hasFilters = false;

            Object.keys(activeFilters).forEach(key => {{
                if (activeFilters[key]) {{
                    hasFilters = true;
                    let displayKey = key === 'AUDIO_BASE' ? 'AUDIO' : key;
                    pills.innerHTML += `
                        <div class="filter-pill" onclick="toggleFilter('${{key}}', '${{activeFilters[key]}}')">
                            ${{displayKey}}: ${{activeFilters[key]}} ✕
                        </div>
                    `;
                }}
            }});

            bar.style.display = hasFilters ? 'flex' : 'none';
            masterReset.style.display = hasFilters ? 'block' : 'none';
        }};

        const clearAllFilters = (e) => {{
            if(e) e.preventDefault();
            Object.keys(activeFilters).forEach(k => activeFilters[k] = null);
            runFilterPipeline();
        }};

        document.getElementById('clearFiltersBtn').addEventListener('click', clearAllFilters);
        document.getElementById('masterResetBtn').addEventListener('click', clearAllFilters);

        const toggleFilter = (key, val) => {{
            if (val === 'Others') return; 
            if (activeFilters[key] === val) activeFilters[key] = null; 
            else activeFilters[key] = val; 
            runFilterPipeline();
        }};

        const buildClickHandler = (key) => (e, elements, chart) => {{
            if (!elements || elements.length === 0) return;
            const index = elements[0].index;
            let label = chart.data.labels[index];
            if (key === 'NQI') label = label.replace('Score ', '');
            toggleFilter(key, label);
        }};

        const aggData = (data, key, fixedOrder = null, maxCats = 5) => {{
            let counts = {{}};
            let sizes = {{}};
            data.forEach(d => {{
                let val = d[key];
                if (key === 'NQI') val = 'Score ' + val;
                counts[val] = (counts[val] || 0) + 1;
                sizes[val] = (sizes[val] || 0) + d.size_bytes;
            }});

            let labels = [], dataCounts = [], dataSizes = [];

            if (fixedOrder) {{
                labels = fixedOrder.filter(l => counts[l] !== undefined);
                Object.keys(counts).forEach(k => {{ if (!labels.includes(k)) labels.push(k); }});
                dataCounts = labels.map(l => counts[l]);
                dataSizes = labels.map(l => (sizes[l] / (1024**3)).toFixed(2));
            }} else {{
                let sorted = Object.entries(counts).sort((a, b) => b[1] - a[1]);
                if (sorted.length <= maxCats) {{
                    labels = sorted.map(s => s[0]);
                    dataCounts = sorted.map(s => s[1]);
                }} else {{
                    let top = sorted.slice(0, maxCats - 1);
                    labels = top.map(s => s[0]);
                    dataCounts = top.map(s => s[1]);
                    let othersCount = sorted.slice(maxCats - 1).reduce((sum, curr) => sum + curr[1], 0);
                    labels.push('Others');
                    dataCounts.push(othersCount);
                }}
            }}
            return {{ labels, dataCounts, dataSizes }};
        }};

        const initBottomCharts = () => {{
            const legendOff = {{ display: false }};
            const legendOn = {{ display: true, position: 'top', labels: {{ boxWidth: 12, padding: 15, font: {{ size: 11 }} }} }};

            bResChart = new Chart(document.getElementById('resChart'), {{
                type: 'bar', data: {{ labels: [], datasets: [{{ data: [], backgroundColor: palette, borderRadius: 4 }}] }},
                options: {{ plugins: {{ title: {{ display: true, text: 'Library Resolution' }}, legend: legendOff }}, scales: {{ y: {{ beginAtZero: true }} }}, onClick: buildClickHandler('RES') }}
            }});

            bNqiChart = new Chart(document.getElementById('nqiChart'), {{
                type: 'bar', data: {{ labels: [], datasets: [{{ data: [], backgroundColor: [], borderRadius: 4 }}] }},
                options: {{ plugins: {{ title: {{ display: true, text: 'NQI Health Distribution' }}, legend: legendOff }}, scales: {{ y: {{ beginAtZero: true }} }}, onClick: buildClickHandler('NQI') }}
            }});

            bResSizeChart = new Chart(document.getElementById('resSizeChart'), {{
                type: 'doughnut', data: {{ labels: [], datasets: [{{ data: [], backgroundColor: palette, borderWidth: 0 }}] }},
                options: {{ plugins: {{ title: {{ display: true, text: 'Storage Footprint by Res (GB)' }}, legend: legendOn }}, cutout: '65%', onClick: buildClickHandler('RES') }}
            }});

            bCodecChart = new Chart(document.getElementById('codecChart'), {{
                type: 'doughnut', data: {{ labels: [], datasets: [{{ data: [], backgroundColor: palette, borderWidth: 0 }}] }},
                options: {{ plugins: {{ title: {{ display: true, text: 'Video Codecs' }}, legend: legendOn }}, cutout: '65%', onClick: buildClickHandler('VIDEO') }}
            }});

            bAudioChart = new Chart(document.getElementById('audioChart'), {{
                type: 'doughnut', data: {{ labels: [], datasets: [{{ data: [], backgroundColor: palette, borderWidth: 0 }}] }},
                options: {{ plugins: {{ title: {{ display: true, text: 'Audio Codecs' }}, legend: legendOn }}, cutout: '65%', onClick: buildClickHandler('AUDIO_BASE') }}
            }});

            bHdrChart = new Chart(document.getElementById('hdrChart'), {{
                type: 'pie', data: {{ labels: [], datasets: [{{ data: [], backgroundColor: palette, borderWidth: 0 }}] }},
                options: {{ plugins: {{ title: {{ display: true, text: 'Color Volume (HDR vs SDR)' }}, legend: legendOn }}, onClick: buildClickHandler('HDR') }}
            }});
        }};

        const updateBottomCharts = (data) => {{
            const resAgg = aggData(data, 'RES', ['4K', '1080p', '720p', '480p']);
            bResChart.data.labels = resAgg.labels;
            bResChart.data.datasets[0].data = resAgg.dataCounts;
            bResChart.update();

            bResSizeChart.data.labels = resAgg.labels;
            bResSizeChart.data.datasets[0].data = resAgg.dataSizes;
            bResSizeChart.update();

            const nqiAgg = aggData(data, 'NQI', ['Score 7', 'Score 6', 'Score 5', 'Score 4', 'Score 3', 'Score 2', 'Score 1']);
            bNqiChart.data.labels = nqiAgg.labels;
            bNqiChart.data.datasets[0].data = nqiAgg.dataCounts;
            bNqiChart.data.datasets[0].backgroundColor = nqiAgg.labels.map(l => getNqiColor(l));
            bNqiChart.update();

            const vidAgg = aggData(data, 'VIDEO', null, 5);
            bCodecChart.data.labels = vidAgg.labels;
            bCodecChart.data.datasets[0].data = vidAgg.dataCounts;
            bCodecChart.update();

            const audAgg = aggData(data, 'AUDIO_BASE', null, 5);
            bAudioChart.data.labels = audAgg.labels;
            bAudioChart.data.datasets[0].data = audAgg.dataCounts;
            bAudioChart.update();

            const hdrAgg = aggData(data, 'HDR', null, 5);
            bHdrChart.data.labels = hdrAgg.labels;
            bHdrChart.data.datasets[0].data = hdrAgg.dataCounts;
            bHdrChart.update();
        }};

        const buildRows = (items, emptyMsg) => {{
            if (!items.length) return `<tr><td colspan='7'>${{emptyMsg}}</td></tr>`;
            return items.map(f => `<tr class="clickable-row" onclick="openFileModal('${{f.id}}')">
                <td>${{f.file}}</td><td>${{f.RES}}</td><td>${{f.VIDEO}}</td><td>${{f.HDR}}</td><td>${{f.AUDIO}}</td>
                <td><span class="badge" style="background-color: ${{getNqiColor(f.NQI)}}; color: ${{getNqiTextColor(f.NQI)}};">${{f.NQI}}</span></td>
                <td class="text-right">${{f.SIZE}}</td>
            </tr>`).join('');
        }};

        const updateTables = (data) => {{
            const sortedByObj = [...data].sort((a,b) => b.size_bytes - a.size_bytes);
            
            const trn = sortedByObj.filter(f => ['6','7'].includes(f.NQI)).slice(0, 10);
            const upg = sortedByObj.filter(f => ['1','2'].includes(f.NQI)).slice(0, 10);
            const top = sortedByObj.slice(0, 10);

            document.getElementById('table-transcode').innerHTML = buildRows(trn, "No transcode targets found matching current filters.");
            document.getElementById('table-upgrade').innerHTML = buildRows(upg, "No upgrade targets found matching current filters.");
            document.getElementById('table-largest').innerHTML = buildRows(top, "No files found.");
        }};

        // --- TREND CHARTS (GLOBAL/HISTORY) ---
        const histDates = historyLog.map(h => h.date);
        
        const getHistTb = (entry, score) => {{ const gb = entry.nqi?.sizes_gb?.[score] || 0; return (gb / 1024).toFixed(2); }};
        const tb7 = historyLog.map(e => getHistTb(e, '7'));
        const tb6 = historyLog.map(e => getHistTb(e, '6'));
        const tb5 = historyLog.map(e => getHistTb(e, '5'));
        const tb4 = historyLog.map(e => getHistTb(e, '4'));
        const tb3 = historyLog.map(e => getHistTb(e, '3'));
        const tb2 = historyLog.map(e => getHistTb(e, '2'));
        const tb1 = historyLog.map(e => getHistTb(e, '1'));

        const calcPct = (entry, score) => {{
            const gb = entry.nqi?.sizes_gb?.[score] || 0;
            const total = (entry.nqi?.sizes_gb && Object.values(entry.nqi.sizes_gb).reduce((a,b)=>a+b,0)) || entry.total_gb || 1;
            return ((gb / total) * 100).toFixed(2);
        }};
        const pct7 = historyLog.map(e => calcPct(e, '7'));
        const pct6 = historyLog.map(e => calcPct(e, '6'));
        const pct5 = historyLog.map(e => calcPct(e, '5'));
        const pct4 = historyLog.map(e => calcPct(e, '4'));
        const pct3 = historyLog.map(e => calcPct(e, '3'));
        const pct2 = historyLog.map(e => calcPct(e, '2'));
        const pct1 = historyLog.map(e => calcPct(e, '1'));

        const getHistCount = (entry, score) => entry.nqi?.counts?.[score] || 0;
        const c7 = historyLog.map(e => getHistCount(e, '7'));
        const c6 = historyLog.map(e => getHistCount(e, '6'));
        const c5 = historyLog.map(e => getHistCount(e, '5'));
        const c4 = historyLog.map(e => getHistCount(e, '4'));
        const c3 = historyLog.map(e => getHistCount(e, '3'));
        const c2 = historyLog.map(e => getHistCount(e, '2'));
        const c1 = historyLog.map(e => getHistCount(e, '1'));

        const stackedDatasets = (d1, d2, d3, d4, d5, d6, d7) => [
            {{ label: 'NQI 1 (Upgrade)', data: d1, backgroundColor: 'rgba(248, 113, 113, 0.8)', borderColor: '#f87171', fill: true, tension: 0.2 }},
            {{ label: 'NQI 2', data: d2, backgroundColor: 'rgba(251, 146, 60, 0.8)', borderColor: '#fb923c', fill: true, tension: 0.2 }},
            {{ label: 'NQI 3', data: d3, backgroundColor: 'rgba(251, 191, 36, 0.8)', borderColor: '#fbbf24', fill: true, tension: 0.2 }},
            {{ label: 'NQI 4', data: d4, backgroundColor: 'rgba(52, 211, 153, 0.8)', borderColor: '#34d399', fill: true, tension: 0.2 }},
            {{ label: 'NQI 5 (Optimal)', data: d5, backgroundColor: 'rgba(34, 211, 238, 0.8)', borderColor: '#22d3ee', fill: true, tension: 0.2 }},
            {{ label: 'NQI 6', data: d6, backgroundColor: 'rgba(217, 70, 239, 0.4)', borderColor: '#d946ef', fill: true, tension: 0.2 }},
            {{ label: 'NQI 7 (Overkill)', data: d7, backgroundColor: 'rgba(241, 245, 249, 0.9)', borderColor: '#ffffff', fill: true, tension: 0.2 }}
        ];

        const legendConfig = {{ display: true, position: 'top', labels: {{ boxWidth: 12, padding: 15, font: {{ size: 11 }} }} }};

        let chartAbs, chartRel, chartCounts;
        let isSyncing = false;

        const handleHover = (chartId) => (e, elements, chart) => {{
            if (isSyncing) return;
            const statusBar = document.getElementById('statusBar');

            if (!elements || elements.length === 0) {{
                isSyncing = true;
                if(chartAbs) {{ chartAbs.setActiveElements([]); chartAbs.update(); }}
                if(chartRel) {{ chartRel.setActiveElements([]); chartRel.update(); }}
                if(chartCounts) {{ chartCounts.setActiveElements([]); chartCounts.update(); }}
                statusBar.innerHTML = '<div class="status-default">Hover over a timeline chart to inspect specific data points. Click to pin details.</div>';
                isSyncing = false;
                return;
            }}

            const dIndex = elements[0].datasetIndex;
            const index = elements[0].index;
            const date = chart.data.labels[index];

            isSyncing = true;
            const activePoint = [{{datasetIndex: dIndex, index}}];

            if (chartId !== 'abs' && chartAbs) {{ chartAbs.setActiveElements(activePoint); chartAbs.update(); }}
            if (chartId !== 'rel' && chartRel) {{ chartRel.setActiveElements(activePoint); chartRel.update(); }}
            if (chartId !== 'cnt' && chartCounts) {{ chartCounts.setActiveElements(activePoint); chartCounts.update(); }}

            const label = chart.data.datasets[dIndex].label;
            const color = chart.data.datasets[dIndex].borderColor;
            
            const tbVal = chartAbs ? chartAbs.data.datasets[dIndex].data[index] : '0.00';
            const pctVal = chartRel ? chartRel.data.datasets[dIndex].data[index] : '0.00';
            const cntVal = chartCounts ? chartCounts.data.datasets[dIndex].data[index] : '0';

            statusBar.innerHTML = `
                <div class="status-segment">
                    <div class="status-label">Snapshot Date</div>
                    <div class="status-value">${{date}}</div>
                </div>
                <div class="status-segment">
                    <div class="status-label">Category</div>
                    <div class="status-value" style="color: ${{color}};">${{label}}</div>
                </div>
                <div class="status-segment">
                    <div class="status-label">File Count</div>
                    <div class="status-value">${{cntVal}} Files</div>
                </div>
                <div class="status-segment">
                    <div class="status-label">Storage Footprint</div>
                    <div class="status-value">${{tbVal}} TB <span style="color: #64748b; font-size: 0.95rem;">(${{pctVal}}%)</span></div>
                </div>
            `;

            isSyncing = false;
        }};

        const handleClick = (e, elements, chart) => {{
            if (!elements || elements.length === 0) return;
            
            const dIndex = elements[0].datasetIndex;
            const index = elements[0].index;
            const date = chart.data.labels[index];
            const label = chart.data.datasets[dIndex].label;
            const color = chart.data.datasets[dIndex].borderColor;
            
            const entry = historyLog[index];
            const score = (dIndex + 1).toString(); 

            const fileCount = entry.nqi?.counts?.[score] || 0;
            const tbVal = getHistTb(entry, score);
            const pctVal = calcPct(entry, score);
            
            let action = "";
            if (['6','7'].includes(score)) action = "High Priority Transcode. Use HandBrake NVENC loop.";
            else if (['1','2'].includes(score)) action = "High Priority Upgrade. Search via Sonarr/Radarr.";
            else if (['4','5'].includes(score)) action = "Optimal encode. No action required.";
            else action = "Acceptable footprint. Leave as is.";

            const pinnedPanel = document.getElementById('pinnedPanel');
            pinnedPanel.style.display = 'block';
            
            pinnedPanel.innerHTML = `
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                    <h3 style="margin: 0; color: ${{color}};"><span style="color: #e2e8f0;">📌 Pinned Snapshot:</span> ${{label}}</h3>
                    <button onclick="document.getElementById('pinnedPanel').style.display='none'" style="background: transparent; border: 1px solid #475569; color: #94a3b8; padding: 5px 12px; border-radius: 4px; cursor: pointer; transition: all 0.2s;">Close</button>
                </div>
                <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px;">
                    <div><span style="color: #64748b; font-size: 0.8rem; text-transform: uppercase; font-weight:bold;">Date</span><br><strong style="color: #f8fafc; font-size: 1.1rem;">${{date}}</strong></div>
                    <div><span style="color: #64748b; font-size: 0.8rem; text-transform: uppercase; font-weight:bold;">File Count</span><br><strong style="color: #f8fafc; font-size: 1.1rem;">${{fileCount.toLocaleString()}}</strong></div>
                    <div><span style="color: #64748b; font-size: 0.8rem; text-transform: uppercase; font-weight:bold;">Storage Volume</span><br><strong style="color: #f8fafc; font-size: 1.1rem;">${{tbVal}} TB</strong></div>
                    <div><span style="color: #64748b; font-size: 0.8rem; text-transform: uppercase; font-weight:bold;">Library Share</span><br><strong style="color: #f8fafc; font-size: 1.1rem;">${{pctVal}}%</strong></div>
                </div>
                <div style="margin-top: 15px; padding-top: 15px; border-top: 1px solid #334155;">
                    <span style="color: #64748b; font-size: 0.8rem; text-transform: uppercase; font-weight:bold;">Actionable Insight</span><br>
                    <span style="color: #cbd5e1; font-size: 1rem;">${{action}}</span>
                </div>
            `;
        }};

        chartAbs = new Chart(document.getElementById('trendChartAbs'), {{
            type: 'line',
            data: {{ labels: histDates, datasets: stackedDatasets(tb1, tb2, tb3, tb4, tb5, tb6, tb7) }},
            options: {{
                plugins: {{ title: {{ display: true, text: 'Storage by Quality Tier' }}, tooltip: {{ enabled: false }}, legend: legendConfig }},
                scales: {{ x: {{ grid: {{ color: '#334155' }} }}, y: {{ stacked: true, grid: {{ color: '#334155' }}, ticks: {{ callback: (v) => v + ' TB' }} }} }},
                interaction: {{ mode: 'nearest', axis: 'xy', intersect: false }},
                onHover: handleHover('abs'), onClick: handleClick
            }}
        }});

        chartRel = new Chart(document.getElementById('trendChartRel'), {{
